rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // 공용 계정 — 반드시 Firebase Console에서만 생성·비밀번호 관리 (클라이언트에 비밀번호 두지 않기)
    function isSharedNeoRabbit() {
      return signedIn()
        && request.auth.token.email == 'neorabbit@neo-rabbit.app';
    }

    function isAdmin() {
      return signedIn() && (
        isSharedNeoRabbit()
        || (request.auth.token.email != null
          && request.auth.token.email.matches('(?i)^.+@unsat\\.co\\.kr$'))
        || (exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
          && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function profileData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function hasRepProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && profileData().role == 'rep'
        && profileData().repId is string;
    }

    function userRepId() {
      return profileData().repId;
    }

    function repIdWellFormed(rid) {
      return rid is string && rid.size() > 0 && rid.size() <= 128;
    }

    function repDocumentExists(rid) {
      return exists(/databases/$(database)/documents/reps/$(rid));
    }

    function validProfileWrite() {
      return request.resource.data.role is string
        && (request.resource.data.role == 'admin' || request.resource.data.role == 'rep')
        && (request.resource.data.role != 'rep'
            || (request.resource.data.repId is string
                && request.resource.data.repId.size() > 0
                && request.resource.data.repId.size() <= 128));
    }

    function validRepWriteData() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'region', 'phone', 'joinDate', 'status'])
        && d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.region is string && d.region.size() <= 100
        && d.phone is string && d.phone.size() <= 50
        && d.joinDate is string && d.joinDate.size() <= 32
        && d.status is string && d.status.size() <= 32;
    }

    function validStoreWriteData() {
      let d = request.resource.data;
      return d.keys().hasOnly(['repId', 'name', 'type', 'address', 'note', 'date', 'activated'])
        && repIdWellFormed(d.repId)
        && d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.type is string && d.type.size() > 0 && d.type.size() <= 80
        && d.date is string && d.date.size() <= 32
        && d.activated is bool
        && (!d.keys().hasAny(['address']) || (d.address is string && d.address.size() <= 500))
        && (!d.keys().hasAny(['note']) || (d.note is string && d.note.size() <= 2000));
    }

    function validVisitWriteData() {
      let d = request.resource.data;
      return d.keys().hasOnly(['repId', 'name', 'address', 'date', 'result', 'note'])
        && repIdWellFormed(d.repId)
        && d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.result is string && d.result.size() > 0 && d.result.size() <= 120
        && d.date is string && d.date.size() <= 32
        && (!d.keys().hasAny(['address']) || (d.address is string && d.address.size() <= 500))
        && (!d.keys().hasAny(['note']) || (d.note is string && d.note.size() <= 2000));
    }

    function storeRepIdUnchanged() {
      return request.resource.data.repId == resource.data.repId;
    }

    function visitRepIdUnchanged() {
      return request.resource.data.repId == resource.data.repId;
    }

    function validJoinRequestData() {
      let d = request.resource.data;
      return d.keys().hasOnly(['name', 'phone', 'region', 'email', 'createdAt', 'status'])
        && d.name is string && d.name.size() > 0 && d.name.size() <= 200
        && d.phone is string && d.phone.size() > 0 && d.phone.size() <= 50
        && d.region is string && d.region.size() > 0 && d.region.size() <= 100
        && d.email is string && d.email.size() <= 200
        && d.createdAt is string && d.createdAt.size() <= 40
        && d.status is string && d.status == 'pending';
    }

    function validRepAnnouncementData() {
      let d = request.resource.data;
      return d.keys().hasAll(['title', 'body', 'version', 'updatedAt'])
        && d.title is string && d.title.size() <= 200
        && d.body is string && d.body.size() <= 8000
        && d.version is int && d.version >= 0 && d.version < 1000000
        && d.updatedAt is string && d.updatedAt.size() <= 40;
    }

    function validChatMessageData() {
      let d = request.resource.data;
      return d.keys().hasOnly(['from', 'text', 'createdAt'])
        && d.from is string && (d.from == 'admin' || d.from == 'rep')
        && d.text is string && d.text.size() > 0 && d.text.size() <= 2000
        && d.createdAt is string && d.createdAt.size() <= 40;
    }

    function canReadChatRep(repId) {
      return isAdmin()
        || (hasRepProfile() && userRepId() == repId)
        || (isSharedNeoRabbit() && repId == '1');
    }

    function canCreateChatRep(repId) {
      return repDocumentExists(repId) && validChatMessageData()
        && (
          (isAdmin() && request.resource.data.from == 'admin')
          || (hasRepProfile() && userRepId() == repId && request.resource.data.from == 'rep')
          || (isSharedNeoRabbit() && repId == '1' && request.resource.data.from == 'rep')
        );
    }

    match /profiles/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update: if isAdmin() && validProfileWrite();
      allow delete: if isAdmin();
    }

    match /settings/app {
      allow read, write: if isAdmin();
    }

    match /settings/rep_announcement {
      allow read: if signedIn();
      allow write: if isAdmin() && validRepAnnouncementData();
    }

    match /rep_join_requests/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create: if signedIn() && request.auth.uid == uid && validJoinRequestData();
      allow update: if isAdmin()
        || (signedIn()
            && request.auth.uid == uid
            && resource.data.status == 'pending'
            && request.resource.data.status == 'pending'
            && validJoinRequestData());
      allow delete: if isAdmin();
    }

    match /chats/{repId}/messages/{msgId} {
      allow read: if canReadChatRep(repId);
      allow create: if canCreateChatRep(repId);
      allow update, delete: if false;
    }

    match /reps/{repId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && validRepWriteData();
      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if isAdmin() || (hasRepProfile() && resource.data.repId == userRepId());
      allow create: if validStoreWriteData()
        && repDocumentExists(request.resource.data.repId)
        && (isAdmin()
            || (hasRepProfile() && request.resource.data.repId == userRepId()));
      allow update: if validStoreWriteData()
        && repDocumentExists(request.resource.data.repId)
        && (isAdmin()
            || (hasRepProfile()
                && resource.data.repId == userRepId()
                && storeRepIdUnchanged()));
      allow delete: if isAdmin()
        || (hasRepProfile() && resource.data.repId == userRepId());
    }

    match /visits/{visitId} {
      allow read: if isAdmin() || (hasRepProfile() && resource.data.repId == userRepId());
      allow create: if validVisitWriteData()
        && repDocumentExists(request.resource.data.repId)
        && (isAdmin()
            || (hasRepProfile() && request.resource.data.repId == userRepId()));
      allow update: if validVisitWriteData()
        && repDocumentExists(request.resource.data.repId)
        && (isAdmin()
            || (hasRepProfile()
                && resource.data.repId == userRepId()
                && visitRepIdUnchanged()));
      allow delete: if isAdmin()
        || (hasRepProfile() && resource.data.repId == userRepId());
    }
  }
}
